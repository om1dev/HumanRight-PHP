Options -Indexes

# Block direct access to sensitive files
<FilesMatch "^\.(env|gitignore)$">
  Order allow,deny
  Deny from all
</FilesMatch>

RewriteEngine On

RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ /router.php [QSA,L]
